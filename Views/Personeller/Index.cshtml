@model PaginatedListModel<OgrenciBilgiSistemi.Models.PersonelModel>
@using OgrenciBilgiSistemi.Models
@using OgrenciBilgiSistemi.Models.Enums
@inject Microsoft.AspNetCore.Mvc.ModelBinding.IModelMetadataProvider Metadata

@{
    ViewData["Title"] = "Personel İşlemleri";
    var q = ViewData["CurrentFilter"] as string;
    var page = Model.PageIndex;
    var total = Model.TotalPages;
    var count = Model.TotalCount;

    var durum = (PersonelFiltre)(ViewData["Durum"] ?? PersonelFiltre.Aktif);
}

<div class="viewport-scroller">
    <div class="fixed-canvas">
        <div class="card border rounded-4 p-3 p-md-4 mt-4">

            <!-- Başlık + aksiyonlar -->
            <div class="d-flex justify-content-between align-items-center mb-4 flex-nowrap no-wrap-scroll">
                <h3 class="text-primary fw-bold mb-0">@ViewData["Title"]</h3>

                <a class="btn btn-success fw-semibold"
                   asp-controller="Personeller"
                   asp-action="Ekle">
                    <i class="bi bi-plus-lg"></i> Personel Ekle
                </a>
            </div>

            <!-- Filtre Formu -->
            <form method="get"
                  asp-controller="Personeller" asp-action="Index"
                  class="d-flex align-items-end gap-3 flex-nowrap no-wrap-scroll w-100 bg-body-tertiary border rounded-3 p-3 mb-3">

                <!-- Personel Arama -->
                <div>
                    <label for="searchString" class="visually-hidden">Personel</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white"><i class="bi bi-search"></i></span>
                        <input type="text" id="searchString" name="searchString"
                               class="form-control" placeholder="Ad, soyad veya kart no ara…"
                               value="@q" style="width:280px;" />
                    </div>
                </div>

                <div>
                    <label for="durum" class="visually-hidden">Durum</label>
                    <select id="durum" name="durum" class="form-select" style="width:180px;">
                        <option value="0" selected="@(durum == PersonelFiltre.Tum)">Tüm Personeller</option>
                        <option value="1" selected="@(durum == PersonelFiltre.Aktif)">Aktif Personeller</option>
                        <option value="2" selected="@(durum == PersonelFiltre.Pasif)">Pasif Personeller</option>
                    </select>
                </div>

                <!-- Ara -->
                <div class="ms-auto">
                    <button class="btn btn-primary px-3 text-nowrap" type="submit">
                        <i class="bi bi-search me-1"></i> Ara
                    </button>
                </div>
            </form>

            <!-- Liste -->
            @if (Model == null || !Model.Any())
            {
                <div class="alert alert-warning mb-0">
                    <i class="bi bi-exclamation-triangle-fill"></i> Kayıt bulunamadı.
                </div>
            }
            else
            {
                <div class="table-scroll">
                    <table class="table table-hover table-sm align-middle">
                        <thead class="bg-dark text-white">
                            <tr class="text-center">
                                <th class="text-start">
                                    @Html.DisplayNameFor(m => m[0].PersonelAdSoyad)
                                </th>
                                <th>
                                    @Html.DisplayNameFor(m => m[0].PersonelDurum)
                                </th>
                                <th>
                                    @Html.DisplayNameFor(m => m[0].Birim)
                                </th>
                                <th>
                                    @Html.DisplayNameFor(m => m[0].PersonelGorselPath)
                                </th>
                                <th>
                                    @Html.DisplayNameFor(m => m[0].PersonelTelefon)
                                </th>
                                <th>
                                    @Html.DisplayNameFor(m => m[0].PersonelTipi)
                                </th>
                                <th>
                                    @Html.DisplayNameFor(m => m[0].PersonelKartNo)
                                </th>
                                <th>İşlem</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var s in Model)
                            {
                                <tr class="text-center">
                                    <td class="text-start fw-semibold text-primary">@s.PersonelAdSoyad</td>
                                    <td>
                                        <span class="badge @(s.PersonelDurum ? "bg-success" : "bg-danger")">
                                            @(s.PersonelDurum ? "Aktif" : "Pasif")
                                        </span>
                                    </td>
                                    <td>@(s.Birim?.BirimAd ?? "Birim Yok")</td>
                                    <td>
                                        <img src="@(!string.IsNullOrEmpty(s.PersonelGorselPath) ? s.PersonelGorselPath : "/images/default.png")"
                                             alt="Foto" class="rounded-circle border" width="48" height="48" />
                                    </td>
                                    <td>@(s.PersonelTelefon ?? "-")</td>
                                    <td>@s.PersonelTipi.GetDisplayName()</td>
                                    <td>@(s.PersonelKartNo ?? "-")</td>
                                    <td>
                                        <div class="btn-group btn-group-gap" role="group" style="min-width: 200px;">
                                            <a asp-controller="Personeller" asp-action="Guncelle" asp-route-id="@s.PersonelId"
                                               class="btn btn-primary btn-sm">
                                                <i class="bi bi-pencil-square"></i> Güncelle
                                            </a>
                                            <button type="button"
                                                    class="btn btn-danger btn-sm"
                                                    data-bs-toggle="modal"
                                                    data-bs-target="#silModal"
                                                    onclick="document.getElementById('personelId').value='@s.PersonelId'">
                                                <i class="bi bi-trash"></i> Sil
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <!-- Sayfalama -->
                <div class="d-flex justify-content-between align-items-center mt-3">
                    <div class="text-muted">
                        Toplam <strong>@count</strong> kayıt • Sayfa <strong>@(page)</strong>/<strong>@(total)</strong>
                    </div>
                    <div class="btn-group btn-group-gap">
                        <a class="btn btn-outline-secondary @(Model.HasPreviousPage ? "" : "disabled")"
                           asp-action="Index"
                           asp-route-searchString="@q"
                           asp-route-durum="@durum"
                           asp-route-pageNumber="@(page - 1)">
                            ‹ Önceki
                        </a>

                        <a class="btn btn-outline-secondary @(Model.HasNextPage ? "" : "disabled")"
                           asp-action="Index"
                           asp-route-searchString="@q"
                           asp-route-durum="@durum"
                           asp-route-pageNumber="@(page + 1)">
                            Sonraki ›
                        </a>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<!-- Silme Modal -->
<div class="modal fade" id="silModal" tabindex="-1" aria-labelledby="silModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="silModalLabel">Personel Sil</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Bu personeli silmek (pasif yapmak) istediğinize emin misiniz?</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">İptal</button>
                <form id="silForm" method="post" asp-action="Sil" asp-controller="Personeller">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="personelId" name="id" />
                    <button type="submit" class="btn btn-danger">Evet, Sil!</button>
                </form>
            </div>
        </div>
    </div>
</div>