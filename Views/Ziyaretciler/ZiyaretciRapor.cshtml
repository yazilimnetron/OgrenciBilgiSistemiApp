@model OgrenciBilgiSistemi.ViewModels.ZiyaretciRaporVm
@using System.Globalization
@using System.Linq

@{
    ViewData["Title"] = "Ziyaretçi Raporu";
    var culture = CultureInfo.CurrentCulture;

    var toplamZiyaret = Model.Rapor?.Count ?? 0;
    var bugun = Model.Rapor?
        .Count(x => x.GirisZamani.Date == DateTime.Today) ?? 0;
    var suAnIceride = Model.Rapor?
        .Count(x => !x.CikisZamani.HasValue) ?? 0;
}

<div class="viewport-scroller">
    <div class="fixed-canvas">

        <div class="card border rounded-4 p-3 p-md-4 mt-4">

            <!-- Başlık + aksiyonlar -->
            <div class="d-flex gap-2 justify-content-between align-items-center mb-3 flex-nowrap no-wrap-scroll">
                <h3 class="text-primary fw-bold mb-0">@ViewData["Title"]</h3>

                <a class="btn btn-success fw-semibold"
                   asp-controller="Ziyaretciler"
                   asp-action="RaporExcel"
                   asp-route-query="@Model.query"
                   asp-route-startDate="@(Model.StartDate?.ToString("yyyy-MM-dd"))"
                   asp-route-endDate="@(Model.EndDate?.ToString("yyyy-MM-dd"))">
                    <i class="bi bi-file-earmark-excel"></i> Excel'e Aktar
                </a>
            </div>

            <!-- Filtre Formu -->
            <form id="raporFilterForm" method="get"
                  asp-controller="Ziyaretci" asp-action="Rapor"
                  class="d-flex align-items-end gap-3 flex-nowrap no-wrap-scroll w-100 bg-body-tertiary border rounded-3 p-3 mb-3">

                <!-- Ziyaretçi Arama -->
                <div>
                    <label for="query" class="visually-hidden">Ziyaretçi</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white"><i class="bi bi-search"></i></span>
                        <input asp-for="query" id="query" class="form-control"
                               placeholder="Ad/soyad, TC, telefon…" style="width:260px;" />
                    </div>
                </div>

                <!-- Başlangıç Tarihi -->
                <div>
                    <label for="StartDate" class="visually-hidden">Başlangıç</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white"><i class="bi bi-calendar-event"></i></span>
                        <input asp-for="StartDate" id="StartDate" type="date" class="form-control" style="width:170px;" />
                    </div>
                </div>

                <!-- Bitiş Tarihi -->
                <div>
                    <label for="EndDate" class="visually-hidden">Bitiş</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white"><i class="bi bi-calendar-event"></i></span>
                        <input asp-for="EndDate" id="EndDate" type="date" class="form-control" style="width:170px;" />
                    </div>
                </div>

                <!-- Ara -->
                <div class="ms-auto">
                    <button class="btn btn-primary px-3 text-nowrap" type="submit">
                        <i class="bi bi-search me-1"></i> Ara
                    </button>
                </div>
            </form>

            <!-- Liste -->
            @if (Model.Rapor == null || !Model.Rapor.Any())
            {
                <div class="alert alert-warning mb-0">
                    <i class="bi bi-exclamation-triangle-fill"></i> Kayıt bulunamadı.
                </div>
            }
            else
            {
                <div class="table-scroll">
                    <table class="table table-hover table-sm align-middle">
                        <thead class="bg-dark text-white">
                            <tr class="text-center">
                                <th class="text-start">Ziyaretçi</th>
                                <th>TC</th>
                                <th>Telefon</th>
                                <th>Görüştüğü Personel</th>
                                <th>Ziyaret Sebebi</th>
                                <th>Giriş Zamanı</th>
                                <th>Çıkış Zamanı</th>
                                <th>Süre</th>
                                <th>Kart No</th>
                                <th>Durum</th>
                                <th>İşlem</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var s in Model.Rapor)
                            {
                                string badgeText;
                                string badgeClass;

                                if (s.CikisZamani == null)
                                {
                                    badgeText = "İçeride";
                                    badgeClass = "bg-success text-white";
                                }
                                else
                                {
                                    badgeText = "Tamamlandı";
                                    badgeClass = "bg-secondary text-white";
                                }

                                <tr class="text-center">
                                    <td class="text-start">
                                        <a asp-controller="Ziyaretci"
                                           asp-action="Detay"
                                           asp-route-id="@s.ZiyaretciId"
                                           asp-route-returnUrl="@(Context.Request.Path + Context.Request.QueryString)"
                                           class="text-decoration-none">
                                            @s.AdSoyad
                                        </a>
                                    </td>
                                    <td>@s.TcKimlikNo</td>
                                    <td>@s.Telefon</td>
                                    <td>@s.PersonelAdSoyad</td>
                                    <td>@s.ZiyaretSebebi</td>
                                    <td>@s.GirisZamani.ToString("g", culture)</td>
                                    <td>@(s.CikisZamani?.ToString("g", culture) ?? "-")</td>
                                    <td>@(s.SureText ?? "-")</td>
                                    <td>@s.KartNo</td>
                                    <td><span class="badge @badgeClass">@badgeText</span></td>
                                    <td>
                                        <a asp-controller="Ziyaretciler"
                                           asp-action="Detay"
                                           asp-route-id="@s.ZiyaretciId"
                                           asp-route-returnUrl="@(Context.Request.Path + Context.Request.QueryString)"
                                           class="btn btn-outline-primary btn-sm">
                                            <i class="bi bi-info-circle"></i> Detay
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }

        </div>

    </div>
</div>
