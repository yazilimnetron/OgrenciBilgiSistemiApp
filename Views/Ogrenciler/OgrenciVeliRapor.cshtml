@model OgrenciBilgiSistemi.ViewModels.OgrenciVeliRaporVm

@{
    ViewData["Title"] = "Öğrenci - Veli Bilgi Raporu";
    var r = Model.Rapor; // kısaltma
}

<div class="viewport-scroller">
    <div class="fixed-canvas">

        <div class="card border rounded-4 p-3 p-md-4 mt-4">

            <!-- Başlık + aksiyonlar -->
            <div class="d-flex gap-2 justify-content-between align-items-center mb-3 flex-nowrap no-wrap-scroll">
                <h3 class="text-primary fw-bold mb-0">@ViewData["Title"]</h3>

                <a class="btn btn-success fw-semibold"
                   asp-controller="Ogrenciler"
                   asp-action="OgrenciVeliRaporExcel"
                   asp-route-query="@Model.query"
                   asp-route-birimId="@Model.birimId">
                    <i class="bi bi-file-earmark-excel"></i> Excel'e Aktar
                </a>
            </div>

            <!-- Filtre Formu -->
            <form id="raporFilterForm" method="get"
                  asp-controller="Ogrenciler"
                  asp-action="OgrenciVeliRapor"
                  class="d-flex align-items-end gap-3 flex-nowrap no-wrap-scroll w-100 bg-body-tertiary border rounded-3 p-3 mb-3">

                @* Yeni filtreleme her zaman 1. sayfadan başlasın *@
                <input type="hidden" name="page" value="1" />
                <input type="hidden" name="pageSize" value="@(r?.PageSize ?? 50)" />

                <!-- Öğrenci / Veli Arama -->
                <div>
                    <label for="query" class="visually-hidden">Öğrenci / Veli</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white"><i class="bi bi-search"></i></span>
                        <input asp-for="query" id="query" class="form-control"
                               placeholder="Öğrenci / veli adı veya numara…" style="width:280px;" />
                    </div>
                </div>

                <!-- Sınıf / Birim -->
                <div>
                    <label for="birimId" class="visually-hidden">Sınıf</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white"><i class="bi bi-diagram-3"></i></span>
                        <select asp-for="birimId" id="birimId" asp-items="Model.Birimler"
                                class="form-select" style="width:190px;">
                        </select>
                    </div>
                </div>

                <!-- Ara -->
                <div class="ms-auto">
                    <button class="btn btn-primary px-3 text-nowrap" type="submit">
                        <i class="bi bi-search me-1"></i> Ara
                    </button>
                </div>
            </form>

            <!-- Liste -->
            @if (r == null || !r.Any())
            {
                <div class="alert alert-warning mb-0">
                    <i class="bi bi-exclamation-triangle-fill"></i> Kayıt bulunamadı.
                </div>
            }
            else
            {
                <div class="table-scroll">
                    <table class="table table-hover table-sm align-middle">
                        <thead class="bg-dark text-white">
                            <tr class="text-center">
                                <th class="text-start">Öğrenci Adı</th>
                                <th>Sınıf</th>
                                <th>Veli Adı</th>
                                <th>Yakınlık</th>
                                <th>Telefon</th>
                                <th>Meslek</th>
                                <th>İşyeri</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var s in r)
                            {
                                <tr class="text-center">
                                    <td class="text-start">
                                        <a asp-controller="Ogrenciler"
                                           asp-action="Guncelle"
                                           asp-route-id="@s.OgrenciId"
                                           class="text-decoration-none">
                                            @s.OgrenciAdSoyad
                                        </a>
                                    </td>
                                    <td>@s.SinifAd</td>
                                    <td>@s.VeliAdSoyad</td>
                                    <td>@s.Yakinlik</td>
                                    <td>@s.VeliTelefon</td>
                                    <td>@s.VeliMeslek</td>
                                    <td>@s.VeliIsYeri</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <!-- Sayfalama (Önceki / Sonraki + Özet) -->
                <div class="d-flex justify-content-between align-items-center mt-3">
                    <div class="text-muted">
                        Toplam <strong>@r.TotalCount</strong> kayıt • Sayfa <strong>@r.PageIndex</strong>/<strong>@r.TotalPages</strong>
                    </div>
                    <div class="btn-group">
                        <a class="btn btn-outline-secondary @(r.HasPreviousPage ? "" : "disabled")"
                           asp-controller="Ogrenciler"
                           asp-action="OgrenciVeliRapor"
                           asp-route-query="@Model.query"
                           asp-route-birimId="@Model.birimId"
                           asp-route-page="@(r.PageIndex - 1)"
                           asp-route-pageSize="@r.PageSize">
                            ‹ Önceki
                        </a>
                        <a class="btn btn-outline-secondary @(r.HasNextPage ? "" : "disabled")"
                           asp-controller="Ogrenciler"
                           asp-action="OgrenciVeliRapor"
                           asp-route-query="@Model.query"
                           asp-route-birimId="@Model.birimId"
                           asp-route-page="@(r.PageIndex + 1)"
                           asp-route-pageSize="@r.PageSize">
                            Sonraki ›
                        </a>
                    </div>
                </div>
            }

        </div>

    </div>
</div>