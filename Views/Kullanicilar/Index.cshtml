@model PaginatedListModel<OgrenciBilgiSistemi.Models.KullaniciModel>

@{
    ViewData["Title"] = "Kullanıcı İşlemleri";
    var q = ViewData["CurrentFilter"] as string;
    var page = Model.PageIndex;
    var total = Model.TotalPages;
    var count = Model.TotalCount;
}

<div class="viewport-scroller">
    <div class="fixed-canvas">
        <div class="card border rounded-4 p-3 p-md-4 mt-4">

            <!-- Başlık + aksiyonlar -->
            <div class="d-flex justify-content-between align-items-center mb-4 flex-nowrap no-wrap-scroll">
                <h3 class="text-primary fw-bold mb-0">@ViewData["Title"]</h3>

                <a class="btn btn-success fw-semibold"
                   asp-controller="Kullanicilar"
                   asp-action="Ekle">
                    <i class="bi bi-plus-lg"></i> Kullanıcı Ekle
                </a>
            </div>

            <!-- Filtre Formu (sabit düzen: mobil uyum yok, yatay kaydırma var) -->
            <form method="get"
                  asp-controller="Kullanicilar" asp-action="Index"
                  class="d-flex align-items-end gap-3 flex-nowrap no-wrap-scroll w-100 bg-body-tertiary border rounded-3 p-3 mb-3">

                <!-- Kullanıcı Arama -->
                <div>
                    <label for="searchString" class="visually-hidden">Kullanıcı</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white"><i class="bi bi-search"></i></span>
                        <input type="text" id="searchString" name="searchString"
                               class="form-control" placeholder="Kullanıcı adı ara…"
                               value="@q" style="width:280px;" />
                    </div>
                </div>

                <!-- Ara -->
                <div class="ms-auto">
                    <button class="btn btn-primary px-3 text-nowrap" type="submit">
                        <i class="bi bi-search me-1"></i> Ara
                    </button>
                </div>
            </form>

            <!-- Liste -->
            @if (Model == null || !Model.Any())
            {
                <div class="alert alert-warning mb-0">
                    <i class="bi bi-exclamation-triangle-fill"></i> Kayıt bulunamadı.
                </div>
            }
            else
            {
                <div class="table-scroll">
                    <table class="table table-hover table-sm align-middle">
                        <thead class="bg-dark text-white">
                            <tr class="text-center">
                                <th class="text-start">Kullanıcı Adı</th>
                                <th>Durum</th>
                                <th>Birimi</th>
                                <th>İşlem</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var s in Model)
                            {
                                <tr class="text-center">
                                    <td class="text-start fw-semibold text-primary">@s.KullaniciAdi</td>
                                    <td>
                                        <span class="badge @(s.KullaniciDurum ? "bg-success" : "bg-danger")">
                                            @(s.KullaniciDurum ? "Aktif" : "Pasif")
                                        </span>
                                    </td>
                                    <td>@(s.Birim?.BirimAd ?? "Birim Yok")</td>
                                    <td>
                                        <div class="btn-group btn-group-gap" role="group" aria-label="İşlemler" style="min-width: 220px;">
                                            <a asp-controller="Kullanicilar" asp-action="Guncelle" asp-route-id="@s.KullaniciId"
                                               class="btn btn-primary btn-sm">
                                                <i class="bi bi-pencil-square"></i> Güncelle
                                            </a>
                                            <a asp-controller="Kullanicilar" asp-action="YetkiGuncelle" asp-route-id="@s.KullaniciId"
                                               class="btn btn-info btn-sm">
                                                <i class="bi bi-shield-lock"></i> Yetki Güncelle
                                            </a>
                                            <button type="button"
                                                    class="btn btn-danger btn-sm"
                                                    data-bs-toggle="modal"
                                                    data-bs-target="#silModal"
                                                    onclick="document.getElementById('kullaniciId').value='@s.KullaniciId'">
                                                <i class="bi bi-trash"></i> Sil
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="d-flex justify-content-between align-items-center mt-3">
                    <div class="text-muted">
                        Toplam <strong>@count</strong> kayıt • Sayfa <strong>@(page)</strong>/<strong>@(total)</strong>
                    </div>
                    <div class="btn-group btn-group-gap">
                        <a class="btn btn-outline-secondary @(Model.HasPreviousPage ? "" : "disabled")"
                           asp-action="Index"
                           asp-route-searchString="@q"
                           asp-route-page="@(page - 1)">
                            ‹ Önceki
                        </a>

                        <a class="btn btn-outline-secondary @(Model.HasNextPage ? "" : "disabled")"
                           asp-action="Index"
                           asp-route-searchString="@q"
                           asp-route-page="@(page + 1)">
                            Sonraki ›
                        </a>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<!-- Silme Modal -->
<div class="modal fade" id="silModal" tabindex="-1" aria-labelledby="silModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="silModalLabel">Kullanıcı Sil</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Bu kullanıcıyı silmek istediğinize emin misiniz?</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">İptal</button>
                <form id="silForm" method="post" asp-action="Sil">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="kullaniciId" name="id" />
                    <button type="submit" class="btn btn-danger">Evet, Sil!</button>
                </form>
            </div>
        </div>
    </div>
</div>