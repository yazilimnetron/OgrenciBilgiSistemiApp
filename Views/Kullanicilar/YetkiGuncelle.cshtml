@model OgrenciBilgiSistemi.ViewModels.KullaniciMenuAtamaVm
@{
    ViewData["Title"] = "Menü Yetkilerini Güncelle";
}

<h4 class="mb-3">
    <i class="bi bi-key me-1"></i> @Model.KullaniciAdi – Menü Yetkileri
</h4>

<form asp-action="YetkiGuncelle" method="post" class="card card-body">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="KullaniciId" />

    <div id="menuTree" class="menu-tree">
        @* Hiyerarşik render *@
        @if (Model.Menuler != null && Model.Menuler.Count > 0)
        {
            <ul class="list-unstyled">
                @foreach (var node in Model.Menuler)
                {
                    @Html.Partial("_MenuTree", node)
                }
            </ul>
        }
        else
        {
            <div class="alert alert-info">Tanımlı menü bulunamadı.</div>
        }
    </div>

    <div id="selectedIdsContainer"></div>

    <div class="d-flex gap-2 mt-3">
        <button type="submit" class="btn btn-primary btn-sm">
            <i class="bi bi-save me-1"></i> Kaydet
        </button>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i> Geri
        </a>
    </div>
</form>

@section Scripts {
    <script>
        (function () {
          // ---- Parent/Child senkronizasyonu + indeterminate ----
          const treeEl = document.getElementById('menuTree');
          treeEl.querySelectorAll('details').forEach(d => d.open = true);
          if (!treeEl) return;

          // Checkbox’ları bul
          const checks = treeEl.querySelectorAll('input[type="checkbox"][data-menu-id]');
          const byId = new Map();
          checks.forEach(ch => byId.set(ch.dataset.menuId, ch));

          // Parent -> children ilişkisini hazırla
          // data-parent-id: null veya sayı
          const childrenMap = new Map(); // parentId -> childCheckbox[]
          checks.forEach(ch => {
            const parentId = ch.dataset.parentId || "";
            if (!childrenMap.has(parentId)) childrenMap.set(parentId, []);
            childrenMap.get(parentId).push(ch);
          });

          // Çocukları parent’a göre ayarla
          function setChildren(parent, checked) {
            const pid = parent.dataset.menuId;
            const list = childrenMap.get(pid);
            if (!list) return;

            list.forEach(ch => {
              ch.checked = checked;
              ch.indeterminate = false;
              setChildren(ch, checked);
            });
          }

          // Parent’ların indeterminate durumunu güncelle
          function updateParents(child) {
            const parentId = child.dataset.parentId;
            if (!parentId) return;

            const parent = byId.get(parentId);
            if (!parent) return;

            const siblings = childrenMap.get(parentId) || [];
            const allChecked = siblings.every(x => x.checked);
            const noneChecked = siblings.every(x => !x.checked && !x.indeterminate);

            if (allChecked) {
              parent.checked = true;
              parent.indeterminate = false;
            } else if (noneChecked) {
              parent.checked = false;
              parent.indeterminate = false;
            } else {
              parent.checked = false;
              parent.indeterminate = true;
            }
            updateParents(parent);
          }

          // Başlangıç: var olan IsAssigned işaretlerine göre indeterminate’leri hesapla
          checks.forEach(ch => ch.indeterminate = false);
          // Ağaç yukarı doğru bir kez geçerek indeterminate’leri kur
          // (Yapraklardan başlayıp parent’a)
          Array.from(checks).reverse().forEach(updateParents);

          // Değişiklik olayları
          checks.forEach(ch => {
            ch.addEventListener('change', () => {
              // Parent işaretlendiyse tüm altları ayarla
              setChildren(ch, ch.checked);
              // Sonra parent zincirini güncelle
              updateParents(ch);
            });
          });

          // Form submit’te seçilen ID’leri gizli inputlara yaz
          const form = treeEl.closest('form');
          const selectedContainer = document.getElementById('selectedIdsContainer');

          function rebuildSelectedIds() {
            // Temizle
            selectedContainer.innerHTML = '';
            // Sadece checked olanları gönder (indeterminate veya unchecked gönderme)
            checks.forEach(ch => {
              if (ch.checked) {
                const hid = document.createElement('input');
                hid.type = 'hidden';
                hid.name = 'SelectedMenuIds';
                hid.value = ch.dataset.menuId;
                selectedContainer.appendChild(hid);
              }
            });
          }

          form.addEventListener('submit', () => {
            rebuildSelectedIds();
          });

          // Tümünü aç/kapa (sadece görsel expand/collapse)
          const btnExpandAll = document.getElementById('btnExpandAll');
          if (btnExpandAll) {
            let expanded = false;
            btnExpandAll.addEventListener('click', () => {
              expanded = !expanded;
              treeEl.querySelectorAll('details').forEach(d => d.open = expanded);
            });
          }
        })();
    </script>
}