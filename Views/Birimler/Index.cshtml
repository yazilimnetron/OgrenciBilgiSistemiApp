@model PaginatedListModel<OgrenciBilgiSistemi.Models.BirimModel>
@using OgrenciBilgiSistemi.Models
@using OgrenciBilgiSistemi.Models.Enums
@using System.Linq

@{
    ViewData["Title"] = "Birim İşlemleri";
    var q = ViewData["CurrentFilter"] as string;
    var page = Model.PageIndex;
    var total = Model.TotalPages;
    var count = Model.TotalCount;

    var durum = (BirimFiltre)(ViewData["Durum"] ?? BirimFiltre.Aktif);
}

<div class="viewport-scroller">
    <div class="fixed-canvas">
        <div class="card border rounded-4 p-3 p-md-4 mt-4">

            <!-- Başlık + aksiyonlar -->
            <div class="d-flex justify-content-between align-items-center mb-4 flex-nowrap no-wrap-scroll">
                <h3 class="text-primary fw-bold mb-0">@ViewData["Title"]</h3>
                <a class="btn btn-success fw-semibold" asp-action="Ekle">
                    <i class="bi bi-plus-lg"></i> Birim Ekle
                </a>
            </div>

            <!-- Filtre -->
            <form method="get" asp-action="Index"
                  class="d-flex align-items-end gap-3 flex-nowrap no-wrap-scroll w-100 bg-body-tertiary border rounded-3 p-3 mb-3">
                <div>
                    <label for="searchString" class="visually-hidden">Birim</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white"><i class="bi bi-search"></i></span>
                        <input type="text" id="searchString" name="searchString"
                               class="form-control" placeholder="Birim adı ara…"
                               value="@q" style="width:280px;" />
                    </div>
                </div>

                <!-- 🔹 Birim Durumu Filtresi -->
                <div>
                    <label for="durum" class="visually-hidden">Durum</label>
                    <select id="durum" name="durum" class="form-select" style="width:180px;">
                        <option value="0" selected="@(durum == BirimFiltre.Tum)">Tüm Birimler</option>
                        <option value="1" selected="@(durum == BirimFiltre.Aktif)">Aktif Birimler</option>
                        <option value="2" selected="@(durum == BirimFiltre.Pasif)">Pasif Birimler</option>
                    </select>
                </div>

                <div class="ms-auto">
                    <button class="btn btn-primary px-3 text-nowrap" type="submit">
                        <i class="bi bi-search me-1"></i> Ara
                    </button>
                </div>
            </form>

            <!-- Liste -->
            @if (Model == null || !Model.Any())
            {
                <div class="alert alert-warning mb-0">
                    <i class="bi bi-exclamation-triangle-fill"></i> Kayıt bulunamadı.
                </div>
            }
            else
            {
                <div class="table-scroll">
                    <table class="table table-hover table-sm align-middle text-center">
                        <thead class="bg-dark text-white">
                            <tr>
                                <th class="text-start">@Html.DisplayNameFor(m => m[0].BirimAd)</th>
                                <th>@Html.DisplayNameFor(m => m[0].BirimSinifMi)</th>
                                <th>@Html.DisplayNameFor(m => m[0].BirimDurum)</th>
                                <th>İşlemler</th>
                            </tr>
                        </thead>
                        <tbody class="bg-white">
                            @foreach (var s in Model)
                            {
                                <tr>
                                    <td class="text-start fw-semibold text-primary">@s.BirimAd</td>
                                    <td>
                                        <span class="badge @(s.BirimSinifMi ? "bg-success" : "bg-danger")">
                                            @(s.BirimSinifMi ? "Evet" : "Hayır")
                                        </span>
                                    </td>
                                    <td>
                                        <span class="badge @(s.BirimDurum ? "bg-success" : "bg-danger")">
                                            @(s.BirimDurum ? "Aktif" : "Pasif")
                                        </span>
                                    </td>
                                    <td>
                                        <div class="btn-group btn-group-gap" role="group" style="min-width: 180px;">
                                            <a asp-action="Guncelle" asp-route-id="@s.BirimId" class="btn btn-primary btn-sm">
                                                <i class="bi bi-pencil-square"></i> Güncelle
                                            </a>
                                            <button type="button" class="btn btn-danger btn-sm"
                                                    data-bs-toggle="modal" data-bs-target="#silModal"
                                                    onclick="document.getElementById('birimId').value='@s.BirimId'">
                                                <i class="bi bi-trash"></i> Sil
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <!-- Sayfalama -->
                <div class="d-flex justify-content-between align-items-center mt-3">
                    <div class="text-muted">
                        Toplam <strong>@count</strong> kayıt • Sayfa <strong>@(page)</strong>/<strong>@(total)</strong>
                    </div>
                    <div class="btn-group btn-group-gap">
                        <a class="btn btn-outline-secondary @(Model.HasPreviousPage ? "" : "disabled")"
                           asp-action="Index"
                           asp-route-searchString="@q"
                           asp-route-durum="@((int)durum)"
                           asp-route-pageNumber="@(page - 1)">
                            ‹ Önceki
                        </a>

                        <a class="btn btn-outline-secondary @(Model.HasNextPage ? "" : "disabled")"
                           asp-action="Index"
                           asp-route-searchString="@q"
                           asp-route-durum="@((int)durum)"
                           asp-route-pageNumber="@(page + 1)">
                            Sonraki ›
                        </a>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<!-- Silme Modal -->
<div class="modal fade" id="silModal" tabindex="-1" aria-labelledby="silModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="silModalLabel">Birim Sil</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body"><p>Bu birimi silmek istediğinize emin misiniz?</p></div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">İptal</button>
                <form id="silForm" method="post" asp-action="Sil">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="birimId" name="id" />
                    <button type="submit" class="btn btn-danger">Evet, Sil!</button>
                </form>
            </div>
        </div>
    </div>
</div>