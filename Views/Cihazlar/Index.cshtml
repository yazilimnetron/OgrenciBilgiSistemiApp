@model PaginatedListModel<OgrenciBilgiSistemi.Models.CihazModel>
@using OgrenciBilgiSistemi.Models.Enums

@{
    ViewData["Title"] = "Cihaz İşlemleri";
    var q = ViewData["CurrentFilter"] as string;
    var page = Model.PageIndex;
    var total = Model.TotalPages;
    var count = Model.TotalCount;
}

<div class="viewport-scroller">
    <div class="fixed-canvas">
        <div class="card border rounded-4 p-3 p-md-4 mt-4">

            <!-- Başlık + aksiyonlar -->
            <div class="d-flex justify-content-between align-items-center mb-4 flex-nowrap no-wrap-scroll">
                <h3 class="text-primary fw-bold mb-0">@ViewData["Title"]</h3>

                <div class="d-flex flex-wrap gap-2">
                    <a asp-action="Ekle" class="btn btn-success fw-semibold">
                        <i class="bi bi-plus-lg"></i> Cihaz Ekle
                    </a>
                    <a asp-action="ExportToExcel" asp-route-searchString="@q" class="btn btn-outline-success fw-semibold">
                        <i class="bi bi-file-earmark-excel"></i> Excel'e Aktar
                    </a>
                </div>
            </div>

            <!-- Arama -->
            <form method="get" asp-action="Index"
                  class="d-flex align-items-end gap-3 flex-nowrap no-wrap-scroll w-100 bg-body-tertiary border rounded-3 p-3 mb-3">
                <div>
                    <label for="searchString" class="visually-hidden">Cihaz</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white"><i class="bi bi-search"></i></span>
                        <input type="text"
                               id="searchString" name="searchString"
                               class="form-control" placeholder="Cihaz Adı, IP veya GUID…"
                               value="@q" style="width:320px;" />
                    </div>
                </div>

                <div class="ms-auto">
                    <button type="submit" class="btn btn-primary px-3 text-nowrap">
                        <i class="bi bi-search me-1"></i> Ara
                    </button>
                    @if (!string.IsNullOrWhiteSpace(q))
                    {
                        <a asp-action="Index" class="btn btn-outline-secondary ms-2">Temizle</a>
                    }
                </div>
            </form>

            <!-- Liste -->
            @if (Model == null || !Model.Any())
            {
                <div class="alert alert-warning mb-0">
                    <i class="bi bi-exclamation-triangle-fill"></i> Kayıt bulunamadı.
                </div>
            }
            else
            {
                <div class="table-scroll">
                    <table class="table table-hover table-sm align-middle text-center">
                        <thead class="bg-dark text-white">
                            <tr>
                                <th class="text-start">Cihaz Adı</th>
                                <th>Tip</th>
                                <th>İstasyon</th>
                                <th>Cihaz Kodu (GUID)</th>
                                <th>IP</th>
                                <th>Port</th>
                                <th>Durum</th>
                                <th>İşlem</th>
                            </tr>
                        </thead>
                        <tbody class="bg-white">
                            @foreach (var cihaz in Model)
                            {
                                var guidStr = cihaz.CihazKodu.ToString();
                                var zkEksik = (cihaz.DonanimTipi == DonanimTipi.ZKTeco)
                                && (string.IsNullOrWhiteSpace(cihaz.IpAdresi) || !(cihaz.PortNo.HasValue && cihaz.PortNo.Value > 0));

                                <tr class="@(zkEksik ? "table-warning" : "")">
                                    <td class="text-start fw-semibold text-primary">@cihaz.CihazAdi</td>
                                    <td><span class="badge bg-light text-dark border">@cihaz.DonanimTipi</span></td>
                                    <td><span class="badge bg-light text-dark border">@cihaz.IstasyonTipi</span></td>

                                    <td class="text-muted">
                                        <div class="d-flex align-items-center justify-content-center gap-2">
                                            @{
                                                var head = guidStr.Length >= 8 ? guidStr.Substring(0, 8) : guidStr;
                                                var tail = guidStr.Length >= 4 ? guidStr[^4..] : "";
                                            }
                                            <code class="small" title="@guidStr">@head...@tail</code>
                                            <button type="button" class="btn btn-outline-secondary btn-sm"
                                                    data-guid="@guidStr" onclick="copyGuid(this)" title="GUID kopyala">
                                                <i class="bi bi-clipboard"></i>
                                            </button>
                                            <a class="btn btn-outline-primary btn-sm"
                                               asp-controller="KartOku" asp-action="Index"
                                               asp-route-cihazKodu="@guidStr" target="_blank"
                                               title="Kart Okuma panelini bu cihaz için aç">
                                                <i class="bi bi-box-arrow-up-right"></i>
                                            </a>
                                        </div>
                                    </td>

                                    <td class="text-muted">@(string.IsNullOrWhiteSpace(cihaz.IpAdresi) ? "—" : cihaz.IpAdresi)</td>
                                    <td class="text-muted">@(cihaz.PortNo.HasValue && cihaz.PortNo.Value > 0 ? cihaz.PortNo.ToString() : "—")</td>

                                    <td>
                                        <span class="badge @(cihaz.Aktif ? "bg-success" : "bg-danger")">
                                            @(cihaz.Aktif ? "Aktif" : "Pasif")
                                        </span>
                                        @if (zkEksik)
                                        {
                                            <div class="small text-danger mt-1">
                                                <i class="bi bi-exclamation-octagon"></i> IP/Port eksik
                                            </div>
                                        }
                                    </td>

                                    <td>
                                        <div class="d-flex flex-wrap gap-1 justify-content-center">
                                            <form asp-controller="Ogrenciler" asp-action="TopluOgrenciGonder"
                                                  method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="cihazId" value="@cihaz.CihazId" />
                                                <button type="submit" class="btn btn-success btn-sm"
                                                        title="Öğrenci verilerini bu cihaza gönder"
                                                        @(cihaz.DonanimTipi != DonanimTipi.ZKTeco || zkEksik ? "disabled" : null)>
                                                    <i class="bi bi-send-check"></i> Öğrenci Gönder
                                                </button>
                                            </form>

                                            <a asp-action="TumKullanicilariListele" asp-route-cihazId="@cihaz.CihazId"
                                               class="btn btn-outline-secondary btn-sm @(cihaz.DonanimTipi != DonanimTipi.ZKTeco || zkEksik ? "disabled opacity-50 pe-none" : "")"
                                               title="Cihazdaki tüm kullanıcıları listele">
                                                <i class="bi bi-people"></i> Kullanıcılar
                                            </a>

                                            <form asp-action="TumKullanicilariSil" method="post" class="d-inline"
                                                  onsubmit="return confirm('Bu cihazdaki TÜM kullanıcılar silinecek. Emin misiniz?');">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="cihazId" value="@cihaz.CihazId" />
                                                <button type="submit" class="btn btn-outline-danger btn-sm"
                                                        title="Cihazdaki tüm kullanıcıları sil"
                                                        @(cihaz.DonanimTipi != DonanimTipi.ZKTeco || zkEksik ? "disabled" : null)>
                                                    <i class="bi bi-person-x"></i> Tümünü Sil
                                                </button>
                                            </form>

                                            <a asp-action="Guncelle" asp-route-id="@cihaz.CihazId" class="btn btn-primary btn-sm">
                                                <i class="bi bi-pencil"></i> Güncelle
                                            </a>

                                            <button class="btn btn-danger btn-sm"
                                                    data-id="@cihaz.CihazId"
                                                    data-bs-toggle="modal" data-bs-target="#silModal">
                                                <i class="bi bi-trash"></i> Sil
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <!-- Sayfalama -->
                <div class="d-flex justify-content-between align-items-center mt-3">
                    <div class="text-muted">
                        Toplam <strong>@count</strong> kayıt • Sayfa <strong>@(page)</strong>/<strong>@(total)</strong>
                    </div>
                    <div class="btn-group btn-group-gap">
                        <a class="btn btn-outline-secondary @(Model.HasPreviousPage ? "" : "disabled")"
                           asp-action="Index"
                           asp-route-searchString="@q"
                           asp-route-page="@(page - 1)">
                            ‹ Önceki
                        </a>

                        <a class="btn btn-outline-secondary @(Model.HasNextPage ? "" : "disabled")"
                           asp-action="Index"
                           asp-route-searchString="@q"
                           asp-route-page="@(page + 1)">
                            Sonraki ›
                        </a>
                    </div>
                </div>
            }
        </div>

    </div>
</div>

<!-- Silme Modal -->
<div class="modal fade" id="silModal" tabindex="-1" aria-labelledby="silModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="silModalLabel">Cihaz Sil</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Kapat"></button>
            </div>
            <div class="modal-body"><p>Bu cihazı silmek istediğinize emin misiniz?</p></div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">İptal</button>
                <form method="post" asp-controller="Cihazlar" asp-action="Sil">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="cihazId" name="id" />
                    <button type="submit" class="btn btn-danger">Evet, Sil!</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Modal açılırken ID yaz
        document.addEventListener('DOMContentLoaded', function () {
          const modalEl = document.getElementById('silModal');
          if (!modalEl) return;
          modalEl.addEventListener('show.bs.modal', function (ev) {
            const id = ev.relatedTarget?.getAttribute('data-id') ?? '';
            modalEl.querySelector('#cihazId').value = id;
          });
        });

        // GUID Kopyalama
        async function copyGuid(btn) {
          const guid = btn.getAttribute('data-guid');
          try {
            await navigator.clipboard.writeText(guid);
            btn.innerHTML = '<i class="bi bi-clipboard-check"></i>';
            btn.classList.remove('btn-outline-secondary');
            btn.classList.add('btn-success');
            setTimeout(() => {
              btn.innerHTML = '<i class="bi bi-clipboard"></i>';
              btn.classList.remove('btn-success');
              btn.classList.add('btn-outline-secondary');
            }, 1200);
          } catch {
            alert('Kopyalama başarısız oldu.');
          }
        }
    </script>
}