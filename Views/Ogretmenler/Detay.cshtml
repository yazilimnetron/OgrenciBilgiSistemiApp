@model OgrenciBilgiSistemi.Models.OgretmenModel

<div class="viewport-scroller">
    <div class="fixed-canvas">
        <div class="container mt-5">
            <div class="card border-1 rounded-4 p-4">
                <!-- Başlık ve Butonlar -->
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h3 class="text-primary fw-bold">
                        Bağlı Öğrenciler Listesi
                    </h3>
                    <div class="d-flex gap-2">
                        <a asp-action="DetayExportToExcel" asp-route-id="@Model.OgretmenId" class="btn btn-outline-success fw-bold">
                            <i class="bi bi-file-earmark-excel"></i> Excel'e Aktar
                        </a>
                        <a asp-action="DetayExportToPdf" asp-route-id="@Model.OgretmenId" class="btn btn-outline-danger fw-bold">
                            <i class="bi bi-file-earmark-pdf"></i> PDF'e Aktar
                        </a>
                    </div>
                </div>

                <table class="table table-hover text-center align-middle">
                    <thead class="bg-dark text-white">
                        <tr>
                            <th>#</th>
                            <th>Adı Soyadı</th>
                            <th>Nosu</th>
                            <th>Birim</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!(Model.Ogrenciler?.Any() ?? false))
                        {
                            <tr>
                                <td colspan="10" class="p-4">
                                    <div class="alert alert-warning text-center fs-5">
                                        <i class="bi bi-exclamation-triangle-fill"></i> Henüz kayıtlı öğrenci bulunmamaktadır.
                                    </div>
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var ogrenci in Model.Ogrenciler)
                            {
                                <tr>
                                    <td>@ogrenci.OgrenciId</td>
                                    <td>@ogrenci.OgrenciAdSoyad</td>
                                    <td>@ogrenci.OgrenciNo</td>
                                    <td>@(ogrenci.Birim?.BirimAd ?? "-")</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>

            <div class="mt-4">
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="bi bi-arrow-left"></i> Geri Dön
                </a>
            </div>
        </div>
    </div>
</div>