@model OgrenciBilgiSistemi.Models.OgretmenModel
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    var action = (ViewData["Action"] as string) ?? "Ekle";      // "Ekle" | "Guncelle"
    var submitText = (ViewData["SubmitText"] as string) ?? "Kaydet";    // "Kaydet" | "Güncelle"
    var includeId = (bool?)ViewData["IncludeId"] ?? false;       // Güncelle'de true

    var formId = "ogretmenForm";
    var submitBtnId = "submitBtn";

    var birimler = Model?.Birimler ?? new List<SelectListItem>();
}

<div class="viewport-scroller">
    <div class="fixed-canvas">
        <div class="container py-4">
            <div class="row justify-content-center">
                <div class="col-lg-6 col-xxl-5">
                    <div class="card rounded-3 border">
                        <div class="card-header bg-primary text-white text-center">
                            <h4 class="fw-bold mb-0">
                                @(action == "Ekle" ? "Yeni Öğretmen Ekle" : "Öğretmen Güncelle")
                            </h4>
                        </div>

                        <div class="card-body p-4">
                            <form method="post" asp-action="@action" enctype="multipart/form-data" id="@formId" autocomplete="off">
                                @Html.AntiForgeryToken()

                                @if (includeId)
                                {
                                    <input type="hidden" asp-for="OgretmenId" />
                                }

                                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                                <!-- Ad Soyad -->
                                <div class="mb-3">
                                    <label asp-for="OgretmenAdSoyad" class="form-label fw-semibold">Adı Soyadı</label>
                                    <input asp-for="OgretmenAdSoyad" class="form-control" required />
                                    <span asp-validation-for="OgretmenAdSoyad" class="text-danger"></span>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="OgretmenKartNo" class="form-label fw-semibold">Kart No</label>
                                    <input asp-for="OgretmenKartNo"
                                           class="form-control"
                                           inputmode="numeric"
                                           autocomplete="off"
                                           placeholder="Kart numarası" />
                                </div>

                                <!-- Görsel -->
                                <div class="mb-3">
                                    <label asp-for="OgretmenGorselFile" class="form-label fw-semibold">Resim</label>
                                    <input asp-for="OgretmenGorselFile" type="file" class="form-control" accept=".jpg,.jpeg,.png" />
                                    <div class="form-text">Sadece .jpg, .jpeg, .png uzantılı dosyalar yüklenebilir.</div>
                                    <span asp-validation-for="OgretmenGorselFile" class="text-danger"></span>
                                </div>

                                <!-- Durum -->
                                <div class="mb-3">
                                    <label asp-for="OgretmenDurum" class="form-label fw-semibold">Öğretmen Durumu</label>
                                    <select asp-for="OgretmenDurum" class="form-select">
                                        <option value="true">Aktif</option>
                                        <option value="false">Pasif</option>
                                    </select>
                                    <span asp-validation-for="OgretmenDurum" class="text-danger"></span>
                                </div>

                                <!-- Birim -->
                                <div class="mb-4">
                                    <label asp-for="BirimId" class="form-label fw-semibold">Birimi</label>
                                    <select asp-for="BirimId" class="form-select" asp-items="birimler">
                                        <option value="">-- Seçiniz --</option>
                                    </select>
                                    <span asp-validation-for="BirimId" class="text-danger"></span>
                                </div>

                                <!-- Butonlar -->
                                <div class="d-flex justify-content-between gap-2">
                                    <a asp-action="Index" class="btn btn-outline-secondary">
                                        <i class="bi bi-arrow-left"></i> Geri
                                    </a>
                                    <button type="submit" class="btn btn-primary fw-bold" id="@submitBtnId">
                                        <i class="bi bi-save"></i> @submitText
                                    </button>
                                </div>
                            </form>
                        </div> <!-- /card-body -->
                    </div> <!-- /card -->
                </div>
            </div>
        </div> <!-- /container -->
    </div>
</div>

@section Scripts {
    <script>
        // Double-submit koruması (spinner yok)
        (function () {
          const form = document.getElementById('@formId');
          const btn  = document.getElementById('@submitBtnId');
          if (!form || !btn) return;

          form.addEventListener('submit', function () {
            if (form.checkValidity()) {
              btn.disabled = true;
              btn.textContent = '@(submitText.EndsWith("e") ? submitText + "iliyor..." : submitText + "iyor...")';
            }
          });
        })();
    </script>
}