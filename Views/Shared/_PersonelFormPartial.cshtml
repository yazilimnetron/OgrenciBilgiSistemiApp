@model OgrenciBilgiSistemi.Models.PersonelModel
@using Microsoft.AspNetCore.Mvc.Rendering
@using OgrenciBilgiSistemi.Models.Enums

@{
    var action = (ViewData["Action"] as string) ?? "Ekle";
    var submitText = (ViewData["SubmitText"] as string) ?? "Kaydet";
    var includeId = (bool?)ViewData["IncludeId"] ?? false;      

    var formId = "personelForm";
    var submitBtnId = "submitBtn";
}

<div class="viewport-scroller">
    <div class="fixed-canvas">
        <div class="container py-4">
            <div class="row justify-content-center">
                <div class="col-lg-6 col-xxl-5">
                    <div class="card rounded-3 border">
                        <div class="card-header bg-primary text-white text-center">
                            <h4 class="fw-bold mb-0">
                                @(action == "Ekle" ? "Yeni Personel Ekle" : "Personel Güncelle")
                            </h4>
                        </div>

                        <div class="card-body p-4">
                            <form method="post" asp-action="@action" enctype="multipart/form-data" id="@formId" autocomplete="off">
                                @Html.AntiForgeryToken()

                                @if (includeId)
                                {
                                    <input type="hidden" asp-for="PersonelId" />
                                }

                                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                                <!-- Ad Soyad -->
                                <div class="mb-3">
                                    <label asp-for="PersonelAdSoyad" class="form-label fw-semibold"></label>
                                    <input asp-for="PersonelAdSoyad" class="form-control" required />
                                    <span asp-validation-for="PersonelAdSoyad" class="text-danger"></span>
                                </div>

                                <!-- Personel Tipi -->
                                <div class="mb-3">
                                    <label asp-for="PersonelTipi" class="form-label fw-semibold"></label>
                                    <select asp-for="PersonelTipi"
                                            class="form-select"
                                            asp-items="Html.GetEnumSelectList<PersonelTipi>()"></select>
                                    <span asp-validation-for="PersonelTipi" class="text-danger"></span>
                                </div>

                                <!-- Kart No -->
                                <div class="mb-3">
                                    <label asp-for="PersonelKartNo" class="form-label fw-semibold"></label>
                                    <input asp-for="PersonelKartNo"
                                           class="form-control"
                                           inputmode="numeric"
                                           autocomplete="off"
                                           placeholder="Kart numarası" />
                                    <span asp-validation-for="PersonelKartNo" class="text-danger"></span>
                                </div>

                                <!-- Görsel -->
                                <div class="mb-3">
                                    <label asp-for="PersonelGorselFile" class="form-label fw-semibold"></label>
                                    <input asp-for="PersonelGorselFile" type="file" class="form-control" accept=".jpg,.jpeg,.png" />
                                    <div class="form-text">Sadece .jpg, .jpeg, .png uzantılı dosyalar yüklenebilir.</div>
                                    <span asp-validation-for="PersonelGorselFile" class="text-danger"></span>
                                </div>

                                <!-- Email -->
                                <div class="mb-3">
                                    <label asp-for="PersonelEmail" class="form-label fw-semibold"></label>
                                    <input asp-for="PersonelEmail" type="email" class="form-control" placeholder="eposta@ornek.com" />
                                    <span asp-validation-for="PersonelEmail" class="text-danger"></span>
                                </div>

                                <!-- Telefon -->
                                <div class="mb-3">
                                    <label asp-for="PersonelTelefon" class="form-label fw-semibold"></label>
                                    <input asp-for="PersonelTelefon" class="form-control" placeholder="5XXXXXXXXX" />
                                    <span asp-validation-for="PersonelTelefon" class="text-danger"></span>
                                </div>

                                <!-- Durum -->
                                <div class="mb-3">
                                    <label asp-for="PersonelDurum" class="form-label fw-semibold"></label>
                                    <select asp-for="PersonelDurum" class="form-select">
                                        <option value="true">Aktif</option>
                                        <option value="false">Pasif</option>
                                    </select>
                                    <span asp-validation-for="PersonelDurum" class="text-danger"></span>
                                </div>

                                <!-- Birim -->
                                <div class="mb-4">
                                    <label asp-for="BirimId" class="form-label fw-semibold"></label>
                                    <select asp-for="BirimId" class="form-select" asp-items="ViewBag.Birimler">
                                    </select>
                                    <span asp-validation-for="BirimId" class="text-danger"></span>
                                </div>

                                <!-- Butonlar -->
                                <div class="d-flex justify-content-between gap-2">
                                    <a asp-action="Index" class="btn btn-outline-secondary">
                                        <i class="bi bi-arrow-left"></i> Geri
                                    </a>
                                    <button type="submit" class="btn btn-primary fw-bold" id="@submitBtnId">
                                        <i class="bi bi-save"></i> @submitText
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Double-submit koruması
        (function () {
          const form = document.getElementById('@formId');
          const btn  = document.getElementById('@submitBtnId');
          if (!form || !btn) return;

          form.addEventListener('submit', function () {
            if (form.checkValidity()) {
              btn.disabled = true;
              btn.textContent = '@(submitText.EndsWith("e") ? submitText + "iliyor..." : submitText + "iyor...")';
            }
          });
        })();
    </script>
}