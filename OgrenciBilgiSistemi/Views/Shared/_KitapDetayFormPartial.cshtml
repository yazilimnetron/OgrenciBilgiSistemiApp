@model OgrenciBilgiSistemi.Models.KitapDetayModel
@using Microsoft.AspNetCore.Mvc.Rendering
@using OgrenciBilgiSistemi.Models.Enums
@using System.Linq

@{
    var action = (ViewData["Action"] as string) ?? "Ekle";
    var submitText = (ViewData["SubmitText"] as string) ?? "Kaydet";
    var includeId = (bool?)ViewData["IncludeId"] ?? false;

    var formId = "kitapDetayForm";
    var submitBtnId = "submitBtn";

    var kitaplar = Model?.Kitaplar ?? Enumerable.Empty<SelectListItem>();
    var ogrenciler = Model?.Ogrenciler ?? Enumerable.Empty<SelectListItem>();
}

<div class="viewport-scroller">
    <div class="fixed-canvas">
        <div class="container py-4">
            <div class="row justify-content-center">
                <div class="col-lg-6 col-xxl-5">
                    <div class="card rounded-3 border">
                        <div class="card-header bg-primary text-white text-center">
                            <h4 class="fw-bold mb-0">
                                @(action == "Ekle" ? "Detay Ekle" : "Detay Güncelle")
                            </h4>
                        </div>

                        <div class="card-body p-4">
                            <form method="post" asp-action="@action" enctype="multipart/form-data" id="@formId" autocomplete="off">
                                @Html.AntiForgeryToken()

                                @if (includeId)
                                {
                                    <input type="hidden" asp-for="KitapDetayId" />
                                }

                                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                                <!-- Kitap -->
                                <div class="mb-3">
                                    <label asp-for="KitapId" class="form-label fw-semibold">Kitap Adı</label>
                                    <select asp-for="KitapId" class="form-select" asp-items="kitaplar">
                                        <option value="">-- Seçiniz --</option>
                                    </select>
                                    <span asp-validation-for="KitapId" class="text-danger"></span>
                                </div>

                                <!-- Öğrenci -->
                                <div class="mb-3">
                                    <label asp-for="OgrenciId" class="form-label fw-semibold">Öğrenci Adı</label>
                                    <select asp-for="OgrenciId" class="form-select" asp-items="ogrenciler">
                                        <option value="">-- Seçiniz --</option>
                                    </select>
                                    <span asp-validation-for="OgrenciId" class="text-danger"></span>
                                </div>

                                <!-- Alış -->
                                <div class="mb-3">
                                    <label asp-for="KitapAlTarih" class="form-label fw-semibold">Alındığı Tarih</label>
                                    <input asp-for="KitapAlTarih" type="date" class="form-control" />
                                    <span asp-validation-for="KitapAlTarih" class="text-danger"></span>
                                </div>

                                <!-- Veriş -->
                                <div class="mb-3">
                                    <label asp-for="KitapVerTarih" class="form-label fw-semibold">Verildiği Tarih</label>
                                    <input asp-for="KitapVerTarih" type="date" class="form-control" />
                                    <span asp-validation-for="KitapVerTarih" class="text-danger"></span>
                                </div>

                                <!-- Durum -->
                                <div class="mb-4">
                                    <label asp-for="KitapDurum" class="form-label fw-semibold">Durum</label>
                                    <select asp-for="KitapDurum" class="form-select">
                                        <option value="@((int)KitapDurumu.Alındı)">Alındı</option>
                                        <option value="@((int)KitapDurumu.TeslimEdildi)">Teslim Edildi</option>
                                    </select>
                                    <span asp-validation-for="KitapDurum" class="text-danger"></span>
                                </div>

                                <!-- Butonlar -->
                                <div class="d-flex justify-content-between gap-2">
                                    <a asp-controller="KitapDetaylar"
                                       asp-action="Index"
                                       class="btn btn-outline-secondary">
                                        <i class="bi bi-arrow-left"></i> Geri
                                    </a>

                                    <button type="submit"
                                            class="btn btn-primary fw-bold"
                                            id="@submitBtnId">
                                        <i class="bi bi-save"></i> @submitText
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        (function () {
            const form = document.getElementById('@formId');
            const btn  = document.getElementById('@submitBtnId');
            if (!form || !btn) return;

            form.addEventListener('submit', function () {
                // Burada checkValidity ile submit'i bloklamıyoruz, sadece butonu kilitliyoruz.
                btn.disabled = true;
                btn.innerText = '@(submitText.EndsWith("e") ? submitText + "iliyor..." : submitText + "iyor...")';
            });
        })();
    </script>
}

@if (!ViewData.ModelState.IsValid)
{
    <div class="alert alert-danger mt-3">
        <strong>ModelState Hataları (debug):</strong>
        <ul class="mb-0">
            @foreach (var entry in ViewData.ModelState)
            {
                var key = entry.Key;
                foreach (var error in entry.Value.Errors)
                {
                    <li>@key : @error.ErrorMessage</li>
                }
            }
        </ul>
    </div>
}
