@using System.Globalization
@model OgrenciBilgiSistemi.ViewModels.AidatRaporVm

@{
    ViewData["Title"] = "Öğrenci Aidat İşlemleri";

    // Sayfalı liste
    var list = Model.Satirlar;

    string Fmt(DateTime? d) => d.HasValue ? d.Value.ToString("yyyy-MM-dd") : "";
    var culture = CultureInfo.CurrentCulture;

    // 🔹 Sayfa içi toplamlar (yalnızca listelenen satırlar)
    var pageToplamBorc = list?.Sum(s => s.BorcGosterim) ?? 0m;
    var pageToplamOdenen = list?.Sum(s => s.GosterilenOdenen) ?? 0m;
    var pageToplamKalan = list?.Sum(s => s.Kalan) ?? 0m;
}

<div class="viewport-scroller">
    <div class="fixed-canvas">
        <div class="card border rounded-4 p-3 p-md-4 mt-4">

            <!-- Başlık + aksiyonlar -->
            <div class="d-flex justify-content-between align-items-center mb-4 flex-nowrap no-wrap-scroll">
                <h3 class="text-primary fw-bold mb-0">@ViewData["Title"]</h3>

                <a class="btn btn-success fw-semibold"
                   asp-controller="OgrenciAidat"
                   asp-action="AidatRaporExcel"
                   asp-route-query="@Model.query"
                   asp-route-yil="@(Model.yil)"
                   asp-route-birimId="@Model.birimId"
                   asp-route-durum="@((int)Model.durum)"
                   asp-route-bas="@Fmt(Model.bas)"
                   asp-route-bit="@Fmt(Model.bit)"
                   asp-route-includePasif="@(Model.includePasif)">
                    <i class="bi bi-file-earmark-excel"></i> Excel'e Aktar
                </a>
            </div>

            <!-- Filtre Formu -->
            <form id="raporFilterForm" method="get"
                  asp-controller="OgrenciAidat" asp-action="Index"
                  class="d-flex align-items-end gap-3 flex-nowrap no-wrap-scroll w-100 bg-body-tertiary border rounded-3 p-3 mb-3">

                <!-- Öğrenci Arama -->
                <div>
                    <label for="query" class="visually-hidden">Öğrenci</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white"><i class="bi bi-search"></i></span>
                        <input asp-for="query" id="query" class="form-control"
                               placeholder="Ad/soyad veya numara…" style="width:280px;" />
                    </div>
                </div>

                <!-- Yıl -->
                <div>
                    <label for="yil" class="visually-hidden">Yıl</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white"><i class="bi bi-calendar2-week"></i></span>
                        <select asp-for="yil" id="yil" asp-items="Model.Yillar"
                                class="form-select" style="width:160px;"></select>
                    </div>
                </div>

                <!-- Birim -->
                <div>
                    <label for="birimId" class="visually-hidden">Birim</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white"><i class="bi bi-diagram-3"></i></span>
                        <select asp-for="birimId" id="birimId" asp-items="Model.Birimler"
                                class="form-select" style="width:190px;"></select>
                    </div>
                </div>

                <!-- Durum -->
                <div>
                    <label for="durum" class="visually-hidden">Durum</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white"><i class="bi bi-funnel"></i></span>
                        <select asp-for="durum" id="durum" asp-items="Model.Durumlar"
                                class="form-select" style="width:170px;"></select>
                    </div>
                </div>

                <!-- Ara -->
                <div class="ms-auto">
                    <button class="btn btn-primary px-3 text-nowrap" type="submit">
                        <i class="bi bi-search me-1"></i> Ara
                    </button>
                </div>
            </form>

            <!-- Liste -->
            @if (list == null || !list.Any())
            {
                <div class="alert alert-warning mb-0">
                    <i class="bi bi-exclamation-triangle-fill"></i> Kayıt bulunamadı.
                </div>
            }
            else
            {
                <div class="table-scroll">
                    <table class="table table-hover table-sm align-middle">
                        <thead class="bg-dark text-white">
                            <tr class="text-center">
                                <th class="text-start">Öğrenci</th>
                                <th>Öğrenci No</th>
                                <th>Sınıf</th>
                                <th class="text-end">Borç</th>
                                <th class="text-end">Ödenen</th>
                                <th class="text-end">Kalan</th>
                                <th>Durum</th>
                                <th>İşlem</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var s in list)
                            {
                                string badgeText;
                                string badgeClass;
                                if (s.Muaf) { badgeText = "Muaf"; badgeClass = "bg-warning text-dark"; }
                                else if (s.Kapandi) { badgeText = "Kapalı"; badgeClass = "bg-success text-white"; }
                                else { badgeText = "Açık"; badgeClass = "bg-danger text-white"; }

                                <tr class="text-center">
                                    <td class="text-start">
                                        <a asp-controller="OgrenciAidat"
                                           asp-action="OgrenciDetay"
                                           asp-route-id="@s.OgrenciId"
                                           asp-route-yil="@(s.Yil ?? Model.yil)"
                                           class="text-decoration-none">
                                            @s.OgrenciAdSoyad
                                        </a>
                                    </td>
                                    <td>@s.OgrenciNo</td>
                                    <td>@s.OgrenciSinif</td>
                                    <td class="text-end">@s.BorcGosterim.ToString("C", culture)</td>
                                    <td class="text-end">@s.GosterilenOdenen.ToString("C", culture)</td>
                                    <td class="text-end">@s.Kalan.ToString("C", culture)</td>
                                    <td><span class="badge @badgeClass">@badgeText</span></td>
                                    <td>
                                        <a asp-controller="OgrenciAidat"
                                           asp-action="Ozet"
                                           asp-route-ogrenciId="@s.OgrenciId"
                                           asp-route-yil="@(s.Yil ?? Model.yil)"
                                           asp-route-returnUrl="@(Context.Request.Path + Context.Request.QueryString)"
                                           class="btn btn-outline-primary btn-sm">
                                            <i class="bi bi-info-circle"></i> Detay
                                        </a>
                                        <button type="button"
                                                class="btn btn-primary btn-sm"
                                                data-bs-toggle="modal"
                                                data-bs-target="#odemeEkleModal"
                                                data-ogrenciid="@s.OgrenciId"
                                                data-ogrenciad="@s.OgrenciAdSoyad"
                                                data-yil="@Model.yil"
                                                data-returnurl="@(Context.Request.Path + Context.Request.QueryString)">
                                            Ödeme Ekle
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <!-- Sayfalama (sadece Önceki / Sonraki + özet) -->
                <div class="d-flex justify-content-between align-items-center mt-3">
                    <div class="text-muted">
                        Toplam <strong>@list.TotalCount</strong> kayıt •
                        Sayfa <strong>@list.PageIndex</strong>/<strong>@list.TotalPages</strong>
                    </div>
                    <div class="btn-group btn-group-gap">
                        <a class="btn btn-outline-secondary @(list.HasPreviousPage ? "" : "disabled")"
                           asp-action="Index"
                           asp-route-query="@Model.query"
                           asp-route-yil="@(Model.yil)"
                           asp-route-birimId="@Model.birimId"
                           asp-route-durum="@((int)Model.durum)"
                           asp-route-bas="@(Model.bas?.ToString("yyyy-MM-dd"))"
                           asp-route-bit="@(Model.bit?.ToString("yyyy-MM-dd"))"
                           asp-route-includePasif="@(Model.includePasif)"
                           asp-route-page="@(list.PageIndex - 1)"
                           asp-route-pageSize="@list.PageSize">
                            ‹ Önceki
                        </a>

                        <a class="btn btn-outline-secondary @(list.HasNextPage ? "" : "disabled")"
                           asp-action="Index"
                           asp-route-query="@Model.query"
                           asp-route-yil="@(Model.yil)"
                           asp-route-birimId="@Model.birimId"
                           asp-route-durum="@((int)Model.durum)"
                           asp-route-bas="@(Model.bas?.ToString("yyyy-MM-dd"))"
                           asp-route-bit="@(Model.bit?.ToString("yyyy-MM-dd"))"
                           asp-route-includePasif="@(Model.includePasif)"
                           asp-route-page="@(list.PageIndex + 1)"
                           asp-route-pageSize="@list.PageSize">
                            Sonraki ›
                        </a>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@await Html.PartialAsync("_OdemeEkleModal", new OgrenciBilgiSistemi.Dtos.AidatOdemeEkleDto())

@section Scripts {
    <script>
        const odemeModal = document.getElementById('odemeEkleModal');
        odemeModal.addEventListener('show.bs.modal', function (event) {
            const btn = event.relatedTarget;
            document.getElementById('odm-ogrenciId').value = btn.getAttribute('data-ogrenciid');
            document.getElementById('odm-ogrenciAd').value  = btn.getAttribute('data-ogrenciad') || '';
            document.getElementById('odm-returnUrl').value  = btn.getAttribute('data-returnurl') || '';
            document.getElementById('odm-yil').value        = btn.getAttribute('data-yil') || '@Model.yil';
        });
    </script>
}