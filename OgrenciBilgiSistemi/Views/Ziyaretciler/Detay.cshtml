@model OgrenciBilgiSistemi.ViewModels.ZiyaretciDetayViewModel

@{
    ViewData["Title"] = "Ziyaretçi Ziyaret Geçmişi";
    var z = Model.Ziyaretci;
}

<div class="viewport-scroller">
    <div class="fixed-canvas">
        <div class="card rounded-4">

            <div class="card-header rounded-top-4 d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2">
                <h5 class="mb-0 text-primary fw-bold">
                    @Model.Ziyaretci.AdSoyad — Giriş/Çıkış
                </h5>
                <div class="d-flex gap-2">
                    <a asp-controller="Ziyaretciler" asp-action="Index" class="btn btn-sm btn-outline-secondary">
                        <i class="bi bi-arrow-left"></i> Listeye Dön
                    </a>
                </div>
            </div>

            <div class="card-body p-4">

                <!-- Ziyaret Geçmişi Tablosu -->
                <div class="table-scroll">
                    <table class="table table-hover text-center align-middle">
                        <thead class="table-light">
                            <tr>
                                <th class="rounded-start-4">#</th>
                                <th>Giriş Tarihi</th>
                                <th>Çıkış Tarihi</th>
                                <th>Görüştüğü Personel</th>
                                <th>Ziyaret Sebebi</th>
                                <th>Kart No</th>
                                <th>Cihaz</th>
                                <th class="rounded-end-4">Durum</th>
                            </tr>
                        </thead>
                        <tbody class="bg-white">
                            @if (Model.Ziyaretler == null || !Model.Ziyaretler.Any())
                            {
                                <tr>
                                    <td colspan="8" class="p-4">
                                        <div class="alert alert-warning text-center m-0">
                                            <i class="bi bi-exclamation-triangle-fill"></i>
                                            Bu ziyaretçi için kayıtlı ziyaret bulunmamaktadır.
                                        </div>
                                    </td>
                                </tr>
                            }
                            else
                            {
                                var index = 1;
                                foreach (var v in Model.Ziyaretler.OrderByDescending(x => x.GirisZamani))
                                {
                                    <tr>
                                        <td>@index</td>
                                        <td>@v.GirisZamani.ToString("dd.MM.yyyy HH:mm")</td>
                                        <td>
                                            @(v.CikisZamani.HasValue
                                                                                ? v.CikisZamani.Value.ToString("dd.MM.yyyy HH:mm")
                                                                                : "-")
                                </td>
                                <td>@(v.Personel?.PersonelAdSoyad ?? "-")</td>
                                <td>@(v.ZiyaretSebebi ?? "-")</td>
                                <td>@(v.KartNo ?? "-")</td>
                                <td>@(v.CihazId?.ToString() ?? "-")</td>
                                <td>
                                    <span class="badge @(v.AktifMi ? "bg-success" : "bg-secondary")">
                                        @(v.AktifMi ? "Aktif" : "Kapandı")
                                    </span>
                                </td>
                            </tr>
                                                        index++;
                                }
                            }
                        </tbody>
                    </table>
                </div>

            </div>
        </div>

        <!-- Toplam Kayıt (öğrenci sayfasındaki gibi) -->
        <div class="mt-3 text-end">
            <span class="fw-bold text-muted">
                Toplam
                <span class="text-primary">@Model.Ziyaretler?.Count() ?? 0</span>
                ziyaret listelenmiştir.
            </span>
        </div>

    </div>
</div>
