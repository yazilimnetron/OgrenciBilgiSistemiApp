{
  "version": "3.0",
  "defaultProvider": "cdnjs",
  "libraries": [
    {
      "library": "bootstrap@5.3.3",
      "destination": "wwwroot/lib/bootstrap/"
    },
    {
      "library": "jquery@3.7.1",
      "destination": "wwwroot/lib/jquery/"
    },
    {
      "library": "font-awesome@6.7.2",
      "destination": "wwwroot/lib/font-awesome/"
    },
    {
      "library": "signalr.js@2.4.3",
      "destination": "wwwroot/lib/signalr/"
    },
    {
      "library": "microsoft-signalr@8.0.7",
      "destination": "wwwroot/lib/signalr/"
    },
    {
      "provider": "unpkg",
      "library": "@microsoft/signalr@7.0.12",
      "destination": "wwwroot/lib/microsoft/signalr",
      "files": [
        "dist/browser/signalr.min.js"
      ]
    },
    {
      "provider": "jsdelivr",
      "library": "chart.js@latest",
      "destination": "wwwroot/lib/chart.js"
    }
  ]
}